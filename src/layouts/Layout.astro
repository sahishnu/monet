---
import "../styles/global.css";
import { GridOverlay } from "../components/landing/GridOverlay.tsx";
import { GridRulers } from "../components/landing/GridRulers.tsx";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Monet Digital Studio",
  description =
    "Digital experiences that feel like a masterpiece. Web design & development.",
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site ?? Astro.url);
const ogImage = new URL("/og.png", Astro.site ?? Astro.url).href;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#FAFAF8" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL.href} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content={ogImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content={ogImage} />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=Inter:wght@400;500;600;700&family=Rubik:wght@400;500&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="min-h-screen">
    <div class="relative">
      <GridOverlay />
      <div class="relative z-10 min-h-screen">
        <slot />
      </div>
      <GridRulers />
    </div>
  </body>
</html>
